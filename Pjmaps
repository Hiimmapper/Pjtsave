        var emoji = isWinner ? "🏆" : "💬";
        var badgeClass = isWinner ? "badge-winner" : "badge-runner";
        
        var customIcon = L.divIcon({
            className: 'marker-icon',
            html: emoji,
            iconSize: [36, 36],
            iconAnchor: [18, 36],
            popupAnchor: [0, -36]
        });

        var popupHtml = `
            <div class='popup-header'>[${p.loc}] ${p.n}</div>
            <div class='popup-body'>
                <div class='badge ${badgeClass}'>${p.s}</div>
                <div class='comment'>"${p.c}"</div>
            </div>
        `;

        L.marker([p.lat, p.lng], {icon: customIcon})
         .addTo(map)
         .bindPopup(popupHtml, { maxWidth: 280, minWidth: 220 });
    });
    
    // 모바일 브라우저 렌더링 버그(지도 짤림 현상) 방지
    setTimeout(function(){ map.invalidateSize(); }, 300);

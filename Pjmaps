    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <style>
        /* 모바일 전체 화면 최적화 */
        body, html { margin: 0; padding: 0; height: 100%; overflow: hidden; background-color: #2c3e50; font-family: 'Apple SD Gothic Neo', 'Malgun Gothic', sans-serif; }
        #map { position: absolute; top: 0; bottom: 0; left: 0; right: 0; width: 100%; height: 100%; }
        
        /* 상단 플로팅 헤더 디자인 */
        #header { position: absolute; top: 15px; left: 50%; transform: translateX(-50%); z-index: 9999; background: rgba(255, 204, 0, 0.95); padding: 12px 24px; border-radius: 50px; font-size: 17px; font-weight: 900; white-space: nowrap; box-shadow: 0 4px 15px rgba(0,0,0,0.3); color: #1a1a1a; letter-spacing: -0.5px; border: 2px solid #fff; }
        
        /* 팝업창(말풍선) 커스텀 디자인 */
        .leaflet-popup-content-wrapper { border-radius: 12px; box-shadow: 0 4px 20px rgba(0,0,0,0.5); border: 1px solid #ddd; padding: 0; overflow: hidden; }
        .leaflet-popup-content { margin: 0; }
        .popup-header { background: #d32f2f; color: white; padding: 12px 15px; font-size: 16px; font-weight: bold; border-top-left-radius: 11px; border-top-right-radius: 11px; }
        .popup-body { padding: 15px; font-size: 14px; line-height: 1.6; color: #333; background: #fff; }
        .badge { display: inline-block; padding: 4px 10px; border-radius: 20px; font-weight: 800; font-size: 12px; margin-bottom: 8px; }
        .badge-winner { background: #fff3e0; color: #e65100; border: 1px solid #ffe0b2; }
        .badge-runner { background: #e3f2fd; color: #1565c0; border: 1px solid #bbdefb; }
        .comment { margin-top: 8px; color: #555; padding: 8px; background: #f8f9fa; border-radius: 8px; border-left: 3px solid #ffcc00; }
        
        /* 커스텀 마커 아이콘 */
